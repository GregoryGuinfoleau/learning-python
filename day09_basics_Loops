# On peut aussi utiliser les contitions if-else
# avec les list comprehension
# attention à la syntaxe!!!
# Ex:
numbers = [2, -1, 79, 33, -45]

no_if   = [num * 2 for num in numbers] #s yntaxe normale sans if
if_only = [num * 2 for num in numbers if num < 0] # syntaxe juste avec if qui se place APRÈS for... in ...
if_else = [num * 2 if num < 0 else num * 3 for num in numbers] # syntaxe avec if ... else ... qui se place AVANT for



