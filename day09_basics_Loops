# ======================
# [SECTION 5 - Nested Loops]
# ======================

# Une boucle à l'intérieur d'une boucle
# cela permet d'accéder a chaque item à l'intérieur d'une sous-liste
# et bien plus
# Ex:
sales_data = [[12, 17, 22], [2, 10, 3], [5, 12, 13]]

scoops_sold = 0

for location in sales_data:
  print(location)

for location in sales_data:
  for scoops_value in location:
    scoops_sold += scoops_value
print(scoops_sold)


